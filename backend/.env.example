# StockQuest Backend — Environment Variables
# Copy this file to .env and fill in real values

# Server
# StockQuest Backend — Environment Variables
# Copy this file to .env and fill in real values

# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# OpenAI (for AI trade explainer, chatbot, recommendations)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (for real NLP sentiment analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API Key (for FinBERT sentiment analysis)
HUGGINGFACE_API_KEY=your_huggingface_token_here


# NewsAPI Key (for global news headlines)
NEWS_API_KEY=your_newsapi_key_here

# Yahoo finance package requires no API key!
